# Environment Variables
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/my-magic-book

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=price_your_price_id_here

# Nodemailer
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Frontend URL (for CORS & Stripe redirect)
FRONTEND_URL=http://localhost:5173

# Google Cloud Storage
GCP_PROJECT_ID=project-cb135797-17e6-4f18-adf
GCS_BUCKET_NAME=first-webapp-storage
GCS_PDF_FOLDER=magic-fanoose
# Service account key for local dev. In Cloud Run, leave unset and use the runtime SA.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Google AI Studio — Gemini image generation (Nano Banana)
GEMINI_API_KEY=your_aistudio_api_key_here
# Optional override; defaults to gemini-2.5-flash-image
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Replicate — face-swap (cdingram/face-swap)
REPLICATE_API_TOKEN=r8_your_replicate_token_here
# Optional override of the model version
REPLICATE_FACESWAP_VERSION=d1d6ea8c8be89d664a07a457526f7128109dee7030fdac424788d762c71ed111

# Public backend URL — used to build the print-file URLs that BookPod fetches.
# In production this MUST be the public address of this backend (not localhost).
PUBLIC_API_URL=http://localhost:5001/api

# BookPod print-on-demand. Leave BOTH unset to skip auto-submission (books are
# still built and uploaded; they just aren't sent to the printer automatically).
BOOKPOD_API_URL=
BOOKPOD_API_KEY=

# Print: per-interior-page paper thickness (mm), used to size the wraparound spine.
PRINT_PAGE_THICKNESS_MM=0.13

# Admin preview generation only: the sample kid photo for theme/coloring previews.
PREVIEW_REFERENCE_PHOTO=gs://first-webapp-storage/magic-fanoose/child-photos/93a8030b-750b-4f91-943d-0d1423a09137.jpeg
